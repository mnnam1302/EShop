# ============================================
# 2. Create category
# ============================================
POST {{Catalog_Write_Url}}/api/v1/categories
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "name": "Clothes",
    "reference": "clothes",
    "slug": "https://example.com/blog/clothes-url-slug"
}

###

# ============================================
# 3. Get category
# ============================================
GET {{Catalog_Read_Url}}/api/v1/categories?page[number]=1&page[size]=10
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###

# ============================================
# 4. Create product SPU
# ============================================
POST {{Catalog_Write_Url}}/api/v1/products
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "name": "Ao thun han quoc - Nam",
    "description": "Bề mặt cải mịn và nhẹ tăng sự co giãn để bạn thoải mái tập luyện",
    "categoryId": "acc2b36b-06df-4181-a330-29dab70c4c8d",
    "images": ["https://thumbs.shopdev.com/p/thumb123456"]
}

###

# ============================================
# 5. Get product
# ============================================
GET {{Catalog_Read_Url}}/api/v1/products?page[number]=1&page[size]=10
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###

# ============================================
# 4. Add variantion dimension
# ============================================
POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/variation-dimensions
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "name": "Color",
    "displayName": "Color",
    "values": ["Red", "Blue", "Green"],
    "displayStyle": " Color"
}

###

POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/variation-dimensions
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "name": "Size",
    "displayName": "Size",
    "values": ["S", "M", "L", "XL"],
    "displayStyle": " Text"
}

 ###

# ============================================
# 5. Add variantion dimension
# ============================================
POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/variation-dimensions
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "name": "Color",
    "displayName": "Color",
    "values": ["Red", "Blue", "Green"],
    "displayStyle": " Color"
}

###

# ============================================
# 6. Get product details
# ============================================
GET {{Catalog_Read_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###

# ============================================
# 7. Add variants
# ============================================
POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/variants
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
    "name": "SHIRT-BLU-L",
    "sku": "SHIRT-BLU-L",
    "price": 499,
    "discountPrice": 449,
    "dimensionValues": [
        { "name": "Color", "value": "Blue" },
        { "name": "Size", "value": "L" }
    ]
}

###

POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/variants
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "name": "SHIRT-GRN-S",
  "sku": "SHIRT-GRN-S",
  "price": 299,
  "discountPrice": 290,
  "dimensionValues": [
    { "name": "Color", "value": "Green" },
    { "name": "Size", "value": "S" }
  ]
}

###

# ============================================
# 8. Publish product
# ============================================
POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/publish
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###

# ============================================
# 9. Unpublish product
# ============================================
POST {{Catalog_Write_Url}}/api/v1/products/1aac2bed-f06d-49f3-98f4-422402266dbe/unpublish
Content-Type: application/json
Authorization: Bearer {{accessToken}}

###
