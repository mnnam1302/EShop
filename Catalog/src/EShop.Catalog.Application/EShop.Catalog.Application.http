@Authorization_URL = http://localhost:5002
@Catalog_Write_Url = http://localhost:5003
@Catalog_Read_Url = http://localhost:5004

# ============================================
# 1. Login tenant account
# ============================================

POST {{Authorization_URL}}/api/v1/auth/login
Content-Type: application/json

{
  "username": "owner-account@eshop-staging",
  "password": "owner.eshop-staing-123"
}

