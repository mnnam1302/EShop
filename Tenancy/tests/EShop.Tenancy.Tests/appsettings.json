{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "MassTransit": "Information",
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ]
  },
  "JwtOptions": {
    "Issuer": "http://authorization-api",
    "Audience": "http://authorization-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryHours": 1
  }
}