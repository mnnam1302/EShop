{
  "ConnectionStrings": {
    "DefaultConnection": "Username=tenancy;Password=tenancy-password-dev;Server=localhost;Port=5432;Database=eshop_tenancy"
  },
  "NgSqlVersionOptions": {
    "Major": 17,
    "Minor": 0
  },
  "RedisOptions": {
    "Enabled": true,
    "ConnectionString": "127.0.0.1"
  },
  "MasstransitConfiguration": {
    "Host": "localhost",
    "VHost": "eshop01012025",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest"
  },
  "JwtOptions": {
    "Issuer": "http://authorization",
    "Audience": "http://authorization",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryHours": 1
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "Services": {
    "authorization": "http://localhost:5002"
  }
}
