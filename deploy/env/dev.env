# =============================================================================
# Development — non-sensitive environment variables only.
#
# Rule: ENV = config that is safe to expose (hostnames, ports, feature flags).
#       SECRET = anything credential-related → deploy/secrets/*.txt
#
# Credentials NOT here:
#   Connection strings    → deploy/secrets/tenancy_connstr.txt
#                           deploy/secrets/authorization_connstr.txt
#   RabbitMQ password     → deploy/secrets/rabbitmq_password.txt
# =============================================================================

TZ=Asia/Ho_Chi_Minh

# OpenTelemetry export endpoint (Aspire Dashboard container).
# The dev dashboard runs unsecured (DOTNET_DASHBOARD_UNSECURED_ALLOW_ANONYMOUS),
# so no API key / auth header is required — nothing secret lives in this file.
OTEL_EXPORTER_OTLP_ENDPOINT=http://dashboard:18889
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# RabbitMQ broker startup config.
# RABBITMQ_USER sets the default user name for the broker (non-sensitive).
# Password is injected via deploy/secrets/rabbitmq_password.txt — never here.
RABBITMQ_USER=guest
RABBITMQ_VHOST=eshop01012025

# PostgreSQL superuser password for local dev (plain — not a secret in dev).
POSTGRES_PASSWORD=postgres-dev
