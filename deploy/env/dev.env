# =============================================================================
# Local development environment variables
# Copy from .env.example and fill in values
# =============================================================================

TZ=Asia/Ho_Chi_Minh

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres-dev

# Redis

# RabbitMQ
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
RABBITMQ_DEFAULT_VHOST=eshop01012025

# MongoDB
MONGO_INITDB_ROOT_USERNAME=sa
MONGO_INITDB_ROOT_PASSWORD=sa1302139

# OpenTelemetry export endpoint (Aspire Dashboard container).
# The dashboard's browser UI stays unsecured for dev convenience, but its OTLP
# ingest endpoint requires an API key — a fixed, non-secret dev value (matches
# ASPIRE_API_KEY / DASHBOARD__OTLP__PRIMARYAPIKEY in docker-compose.infra.dev.yml).
OTEL_EXPORTER_OTLP_ENDPOINT=http://dashboard:18889
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_HEADERS=x-otlp-api-key=eshop-dev-otlp-key
