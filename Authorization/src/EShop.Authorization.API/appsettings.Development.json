{
  "ConnectionStrings": {
    "DefaultConnection": "Username=authorization;Password=authorization-password-dev;Server=localhost;Port=5432;Database=eshop_authorization"
  },
  "NgSqlVersionOptions": {
    "Major": 17,
    "Minor": 0
  },
  "JwtOptions": {
    "Issuer": "http://authorization",
    "Audience": "http://authorization",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryHours": 1
  },
  "RsaKeyOptions": {
    "KeySizeInBits": 2048,
    "KeyExpiryInDays": 30
  },
  "RedisOptions": {
    "Enabled": true,
    "Host": "localhost:6379"
  },
  "MasstransitConfiguration": {
    "Host": "localhost",
    "VHost": "eshop01012025",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "Services": {
    "tenancy": "http://localhost:5001"
  },
  "EmailSettings": {
    "DefaultFromEmail": "noreply@eshop.com",
    "Host": "smtp.gmail.com",
    "Port": 587,
    "UserName": "your_email",
    "Password": "your_app_password",
    "EnableSsl": true,
    "TimeoutMilliseconds": 30000
  }
}
