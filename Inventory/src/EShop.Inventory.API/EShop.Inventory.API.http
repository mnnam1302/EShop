# ============================================
# CATALOG API ENDPOINTS
# ============================================

# Get Product by ID (Requires Authentication)
GET {{Catalog_URL}}/api/v1/products
Content-Type: application/vnd.api+json
Authorization: Bearer {{accessToken}}

###

# ============================================
# INVENTORY API ENDPOINTS
# ============================================

# Create Inventory (Requires Authentication)
POST {{Inventory_URL}}/api/v1/inventories
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "productId": "911b2c0b-7924-484a-ad0a-fbd9fbf0b08a",
  "variantId": "214fe0df-9941-46f8-bb45-16ce39d9f3e6",
  "sku": "SHIRT-GRN-S",
  "stockAvailable": 50,
  "minimumStock": 0
}

###

# Get Inventories by Product ID (Requires Authentication)
GET {{Inventory_URL}}/api/v1/inventories?productId=911b2c0b-7924-484a-ad0a-fbd9fbf0b08a
Accept: application/json
Authorization: Bearer {{accessToken}}

###

# Get Inventories by Product ID with Pagination (Requires Authentication)
GET {{Inventory_URL}}/api/v1/inventories?productId=3fa85f64-5717-4562-b3fc-2c963f66afa6&pageIndex=1&pageSize=20
Accept: application/json
Authorization: Bearer {{accessToken}}

###

  
# Create Inventory (Requires Authentication)
PATCH {{Inventory_URL}}/api/v1/inventories
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "variantId": "214fe0df-9941-46f8-bb45-16ce39d9f3e6"
}

###
