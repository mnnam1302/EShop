# ============================================
# CATALOG API ENDPOINTS
# ============================================

# Get Product by ID
GET {{Catalog_URL}}/api/v1/products
Content-Type: application/vnd.api+json
Authorization: Bearer {{accessToken}}

###

# ============================================
# INVENTORY API ENDPOINTS
# ============================================

# Create Inventory
POST {{Inventory_URL}}/api/v1/inventories
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "productId": "1aac2bed-f06d-49f3-98f4-422402266dbe",
  "variantId": "28956cb9-2a93-42b7-96b5-f82916d1c388",
  "sku": "SHIRT-GRN-S",
  "stockAvailable": 50,
  "minimumStock": 0
}

###

POST {{Inventory_URL}}/api/v1/inventories
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "productId": "1aac2bed-f06d-49f3-98f4-422402266dbe",
  "variantId": "3690be10-3fc4-4071-ba89-cb06273bb577",
  "sku": "SHIRT-BLU-L",
  "stockAvailable": 100,
  "minimumStock": 0
}

###

# Get Inventories by Product ID
GET {{Inventory_URL}}/api/v1/inventories?productId=1aac2bed-f06d-49f3-98f4-422402266dbe
Accept: application/json
Authorization: Bearer {{accessToken}}

###

# Get Inventories by Product ID with Pagination
GET {{Inventory_URL}}/api/v1/inventories?productId=1aac2bed-f06d-49f3-98f4-422402266dbe&pageIndex=1&pageSize=20
Accept: application/json
Authorization: Bearer {{accessToken}}

###

  
# Add inventory's stock available from Postgres to Redis
POST {{Inventory_URL}}/api/v1/inventories/warn-up
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "variantId": "28956cb9-2a93-42b7-96b5-f82916d1c388"
}

###
# ============================================
# INVENTORY API ENDPOINTS
# ============================================

# Create Reservation
POST {{Inventory_URL}}/api/v1/reservations
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "orderId": "911b2c0b-7924-484a-ad0a-fbd9fbf0b08a",
  "items": [
    {
      "variantId": "214fe0df-9941-46f8-bb45-16ce39d9f3e6",
      "quantity": 1
    }
  ]
}
