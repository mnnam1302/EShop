{
  "ConnectionStrings": {
    "DefaultConnection": "Username=inventory;Password=inventory-password-dev;Server=localhost;Port=5432;Database=eshop_inventory"
  },
  "RedisOptions": {
    "Enabled": true,
    "Host": "localhost:6379"
  },
  "MasstransitConfiguration": {
    "Host": "localhost",
    "VHost": "eshop01012025",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest"
  },
  "Services": {
    "tenancy": "http://localhost:5001",
    "authorization": "http://localhost:5002"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information",
        "System": "Information",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "Otlp": {
    "Endpoint": "http://localhost:18889",
    "Protocol": "grpc",
    "ApiKey": "eshop-dev-otlp-key"
  }
}
