{
  "RedisOptions": {
    "Enabled": true,
    "ConnectionString": "127.0.0.1"
  },
  "JwtOptions": {
    "Issuer": "http://authorization",
    "Audience": "http://authorization",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryHours": 1
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "tenancy-route": {
        "ClusterId": "tenancy-cluster",
        "Match": {
          "Path": "tenancy-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "authorization-route": {
        "ClusterId": "authorization-cluster",
        "Match": {
          "Path": "authorization-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "tenancy-cluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://tenancy"
          }
        }
      },
      "authorization-cluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://authorization"
          }
        }
      }
    }
  },
  "Services": {
    "tenancy": {
      "http": ["http://localhost:5001"]
    },
    "authorization": {
      "http": ["http://localhost:5002"]
    }
  }
}
