{
  "RedisOptions": {
    "Enabled": true,
    "ConnectionString": "127.0.0.1"
  },
  "JwtOptions": {
    "Issuer": "http://authorizationService",
    "Audience": "http://authorizationService",
    "AccessTokenExpiryMinutes": 5,
    "RefreshTokenExpiryHours": 1
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identityRoute": {
        "ClusterId": "IdentityApiCluster",
        "Match": {
          "Path": "identity-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "tenancyRoute": {
        "ClusterId": "TenancyApiCluster",
        "Match": {
          "Path": "tenancy-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "configurationRoute": {
        "ClusterId": "CatalogApiCluster",
        "Match": {
          "Path": "catalog-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "IdentityApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://IdentityServiceUrl"
          }
        }
      },
      "TenancyApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://TenancyServiceUrl"
          }
        }
      },
      "CatalogApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://CatalogServiceUrl"
          }
        }
      }
    }
  },
  "Services": {
    "IdentityServiceUrl": {
      "http": "http://localhost:2010"
    },
    "TenancyServiceUrl": {
      "http": "http://localhost:2010"
    },
    "CatalogServiceUrl": {
      "http": "http://localhost:3010"
    }
  }
}
