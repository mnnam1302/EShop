{
  "RedisOptions": {
    "Enabled": true,
    "ConnectionString": "127.0.0.1"
  },
  "JwtOptions": {
    "Issuer": "http://authorization-api",
    "Audience": "http://authorization-api",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryHours": 1
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "authorizationRoute": {
        "ClusterId": "AuthorizationApiCluster",
        "Match": {
          "Path": "auth-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "tenancyRoute": {
        "ClusterId": "TenancyApiCluster",
        "Match": {
          "Path": "tenancy-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "catalogRoute": {
        "ClusterId": "CatalogApiCluster",
        "Match": {
          "Path": "catalog-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "AuthorizationApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://authorization"
          }
        }
      },
      "TenancyApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://tenancy"
          }
        }
      },
      "CatalogApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://catalog-api"
          }
        }
      }
    }
  },
  "Services": {
    "tenancy": "http://localhost:5001",
    "authorization": "http://localhost:5002",
    "catalog-api": "http://localhost:5003"
  }
}
