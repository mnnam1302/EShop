{
  "RedisOptions": {
    "Enabled": true,
    "ConnectionString": "redis:6379"
  },
  "JwtOptions": {
    "Issuer": "http://localhost:2000",
    "Audience": "http://localhost:2000",
    "AccessExpireHour": 1,
    "RefreshExpireHour": 6,
    "SecretKey": "7jCDPbBkeW8asPxdIc3jRddWpB7l63fh"
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "Theme": "Serilog.Sinks.SystemConsole.Themes.AnsiConsoleTheme::Code, Serilog.Sinks.Console"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "shared": true
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithProcessId",
      "WithThreadId"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identityRoute": {
        "ClusterId": "IdentityApiCluster",
        "Match": {
          "Path": "identity-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "tenancyRoute": {
        "ClusterId": "TenancyApiCluster",
        "Match": {
          "Path": "identity-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "IdentityApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://IdentityServiceUrl"
          }
        }
      },
      "TenancyApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://TenancyServiceUrl"
          }
        }
      }
    }
  },
  "Services": {
    "IdentityServiceUrl": {
      "http": "http://localhost:2000"
    },
    "TenancyServiceUrl": {
      "http": "http://localhost:2010"
    }
  }
}
