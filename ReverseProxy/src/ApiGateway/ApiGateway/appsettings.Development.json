{
  "RedisOptions": {
    "Enabled": true,
    "ConnectionString": "127.0.0.1"
  },
  "JwtOptions": {
    "Issuer": "http://localhost:2000",
    "Audience": "http://localhost:2000",
    "AccessExpireHour": 1,
    "RefreshExpireHour": 6,
    "SecretKey": "7jCDPbBkeW8asPxdIc3jRddWpB7l63fh"
  },
  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "authApiCluster",
        "Match": {
          "Path": "identity-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      },
      "reinsuranceRoute": {
        "AuthorizationPolicy": "DefaultAuthentication",
        "ClusterId": "reinsuranceApiCluster",
        "Match": {
          "Path": "reinsurance-api/{**catch-all}"
        },
        "Transforms": [
          { "PathPattern": "api/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "authApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://UserService"
          }
        }
      },
      "reinsuranceApiCluster": {
        "Destinations": {
          "Destination1": {
            "Address": "http://ReinsuranceService"
          }
        }
      }
    }
  },
  "Services": {
    "UserService": {
      "http": "http://localhost:2000"
    },
    "ReinsuranceService": {
      "http": "http://localhost:2500"
    }
  }
  //"IdentityHttpClientOptions": {
